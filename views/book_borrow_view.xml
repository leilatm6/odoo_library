<odoo>
    <record id="book_borrow_action" model="ir.actions.act_window">
        <field name="name">Borrow Records</field>
        <field name="res_model">book.borrow</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="book_borrow_view_list" model="ir.ui.view">
        <field name="name">book.borrow.list</field>
        <field name="model">book.borrow</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_id"/>
                <field name="borrower_id"/>
                <field name="state"/>
                <field name="borrow_date"/>
                <field name="due_date"/>
                <field name="return_date" readonly="state != 'borrowed'"/>
            </list>
        </field>
    </record>

    <record id="book_borrow_view_form" model="ir.ui.view">
        <field name="name">book.borrow.form</field>
        <field name="model">book.borrow</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="borrow_book" type="object" string="Borrow"
                            invisible="state != 'new'"/>
                    <button name="return_book" type="object" string="Return"
                            invisible="state != 'borrowed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="borrowed,returned"
                           invisible="state == 'new'"/>
                </header>
                <sheet>
                    <group>
                        <field name="book_id"/>
                        <field name="borrower_id"/>
                        <field name="borrow_date" readonly="state != 'new'"/>
                        <field name="due_date" invisible="state == 'new'"/>
                        <field name="return_date" invisible="state != 'borrowed'" readonly="state != 'borrowed'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>