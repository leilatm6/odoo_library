<odoo>
    <record id="book_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">book.property</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="book_property_view_list" model="ir.ui.view">
        <field name="name">book.property.list</field>
        <field name="model">book.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="available_copies"/>
                
            </list>
        </field>
    </record> 

     <record id="book_property_view_form" model="ir.ui.view">
        <field name="name">book.property.form</field>
        <field name="model">book.property</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- <button name="action_borrow"
                        type="object"
                        string="Borrow"
                        invisible="available_copies &lt;= 0"/> -->

                    <field name="available_copies"/>
                    <div class="alert alert-warning" role="alert"
                        invisible="available_copies &gt; 0" >
                        <strong>Warning!</strong> No copies available for borrowing.
                        </div>
                        
                    
                </header>   
                <sheet>
                    <h1>
                        <field name="title"/>
                    </h1>
                    <group>
                       <!-- <field name="tag_ids" widget="many2many_tags"/> -->
                        <field name="book_type_id"/>
                        <field name="author"/>
                        <field name="isbn"/>
                        <field name="copies"/>
                        <field name="available_copies"/>
                        
                        
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="summary"/>
                                
                            </group>
                        </page>
                        <page string="Borrowing">
                            <field name="current_borrow_ids">
                                <list>
                                    <field name="borrower_id"/>
                                    <field name="state"/>
                                    <field name="borrow_date"/>
                                    <field name="return_date"/>
                                    <field name="due_date"/>    
                                </list>
                            </field>
                        </page>
                        <page string="Photos">
    <field name="photo_ids">
        <kanban>
            <templates>
                <t t-name="card">
                    <field name="photo" widget="image"/>
                    <div><field name="name"/></div>
                </t>
            </templates>
        </kanban>
    </field>
</page>
                    </notebook> 
                </sheet>
            </form>
        </field>
    </record> 

    <record id="book_property_view_kanban" model="ir.ui.view">
        <field name="name">book.property.kanban</field>
        <field name="model">book.property</field>
        <field name="arch" type="xml">
        <kanban default_group_by="book_type_id">
            <!--<field name="copies"/>
            <field name="state"/>-->
            <template>
                <t t-name="card">
                    <field name="title"/>
                    <field name="author"/>
                    <field name="isbn"/>
                    <field name="available_copies"/>
                    <!--<field name="tag_ids" widget="many2many_tags"/>
                    <t t-if ="record.state.raw_value == 'sold'">
                    <div>
                        <span>selling price: </span>
                        <field name="selling_price"/>
                    </div> 
                    </t> -->
                </t>
                

            </template>
        </kanban>
        </field>
    </record> 
</odoo>