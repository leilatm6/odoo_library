<odoo>
    <!-- 1. List view: what you see when you open the Users menu -->
    <record id="lib_users_view_list" model="ir.ui.view">
        <field name="name">lib.users.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="login"/>
                <field name="max_books"/>
            </list>
        </field>
    </record>

    <!-- 2. Form view: opens when you click a user, with a Borrow History tab -->
    <record id="lib_users_view_form" model="ir.ui.view">
        <field name="name">lib.users.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="login"/>
                        <field name="max_books"/>
                        <field name="available_borrows" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Borrow History">
                            <field name="borrowed_book_ids">
                                <list>
                                    <field name="book_id"/>
                                    <field name="state"/>
                                    <field name="borrow_date"/>
                                    <field name="return_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 3. Action: referenced by your existing library_users_menu -->
    <record id="lib_users_action" model="ir.actions.act_window">
        <field name="name">Library Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('lib_users_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('lib_users_view_form')})]"/>
    </record>
</odoo>