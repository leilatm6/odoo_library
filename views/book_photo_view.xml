<odoo>
    <record id="book_photo_view_list" model="ir.ui.view">
        <field name="name">book.photo.list</field>
        <field name="model">book.photo</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="photo_type"/>
                <field name="photo" widget="image" options="{'size': [0, 60]}"/>
            </list>
        </field>
    </record>

    <record id="book_photo_view_form" model="ir.ui.view">
        <field name="name">book.photo.form</field>
        <field name="model">book.photo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="book_id"/>
                        <field name="photo_type"/>
                        <field name="photo" widget="image"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>