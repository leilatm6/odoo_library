<odoo>
    <record id="book_property_type_action" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">book.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

     <record id="book_property_type_view_form" model="ir.ui.view">
        <field name="name">book.property.type.form</field>
        <field name="model">book.property.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                <field name="name" />
                
                </sheet>
            </form>
        </field>
    </record> 

<record id="book_property_type_view_list" model="ir.ui.view">
        <field name="name">book.property.type.list</field>
        <field name="model">book.property.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                
              
            </list>
        </field>
    </record> 

</odoo>