<odoo>
    <record id="lib_users_action" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="lib_users_view_form_inherit" model="ir.ui.view">
        <field name="name">res.users.form.library.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Library">
                    <group>
                        <field name="max_books"/>
                    </group>

                    <field name="borrowed_book_ids" readonly="1">
                        <list create="0" edit="0" delete="0">
                            <field name="book_id"/>
                            <field name="state"/>
                            <field name="borrow_date"/>
                            <field name="return_date"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>