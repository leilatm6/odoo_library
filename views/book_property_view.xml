<odoo>
    <record id="book_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">book.property</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="book_property_view_list" model="ir.ui.view">
        <field name="name">book.property.list</field>
        <field name="model">book.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="copies"/>
            </list>
        </field>
    </record> 

     <record id="book_property_view_form" model="ir.ui.view">
        <field name="name">book.property.form</field>
        <field name="model">book.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <!--<button name="sell_property" type="object" string="Sell" invisible="state in ('sold','canceled')"/>
                        <button name="cancel_property" type="object" string="Cancel" invisible="state in ('sold','canceled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="new,offer_accepted,sold,canceled"/>-->
                    </header>   
                    <h1>
                        <field name="title"/>
                    </h1>
                    <group>
                       <!-- <field name="tag_ids" widget="many2many_tags"/> -->
                        <field name="book_type_id"/>
                        <field name="author"/>
                        <field name="isbn"/>
                        <field name="copies"/>
                        
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="summary"/>
                                
                            </group>
                        </page>
                        <page string="Borrowing">
                            <field name="borrow_ids" mode="list,form"/>
                                </page>
                    </notebook> 
                </sheet>
            </form>
        </field>
    </record> 

    <record id="book_property_view_kanban" model="ir.ui.view">
        <field name="name">book.property.kanban</field>
        <field name="model">book.property</field>
        <field name="arch" type="xml">
        <kanban default_group_by="book_type_id">
            <!--<field name="copies"/>
            <field name="state"/>-->
            <template>
                <t t-name="card">
                    <field name="title"/>
                    <field name="author"/>
                    <field name="isbn"/>
                    <field name="copies"/>
                    <!--<field name="tag_ids" widget="many2many_tags"/>
                    <t t-if ="record.state.raw_value == 'sold'">
                    <div>
                        <span>selling price: </span>
                        <field name="selling_price"/>
                    </div> 
                    </t> -->
                </t>
                

            </template>
        </kanban>
        </field>
    </record> 
</odoo>